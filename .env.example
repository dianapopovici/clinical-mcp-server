# Copy this file to .env and adjust as needed. NEVER commit the real .env.

# --- Clinical RAG Engine (the data source for semantic search) ---
RAG_API_URL=http://localhost:8000

# --- Local read-only data view (structured tools) ---
DATA_PATH=data/synthetic/clinical_records.json

# --- Append-only audit trail ---
AUDIT_LOG_PATH=audit.log

# --- Server transport defaults ---
MCP_HOST=127.0.0.1
MCP_PORT=9000
